# =============================================================================
# 泌尿科 AI 語音問診助手 — 環境變數範本
# 複製此檔案為 .env 並填入實際值
# 注意：請勿將 .env 提交至版本控制
# =============================================================================


# -----------------------------------------------------------------------------
# 應用程式基本設定
# -----------------------------------------------------------------------------
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=your-super-secret-key-at-least-32-characters-long
# 允許的前端來源（CORS），逗號分隔字串或 JSON 陣列皆可
# Gotcha：pydantic-settings v2 對 list[str] 欄位會在 source 層先 json.loads()。
#   app/core/config.py 已對 CORS_ORIGINS（與 MULTILANG_DISABLED_LANGUAGES）加上
#   Annotated[list[str], NoDecode]，讓 field_validator 接到原始字串、同時容忍
#   「逗號分隔」與「JSON 陣列」兩種格式，故修正後兩種寫法皆可。
#   若部署的是舊 code（無 NoDecode），逗號分隔字串會 SettingsError → 容器一啟動即 crash
#   → healthcheck 永遠失敗 → Railway 顯示 offline；此時 CORS_ORIGINS 必須是合法 JSON 陣列：
#   CORS_ORIGINS=["https://your-frontend-domain.com","https://your-admin-domain.com"]
CORS_ORIGINS=https://your-frontend-domain.com,https://your-admin-domain.com
# 日誌等級：DEBUG / INFO / WARNING / ERROR / CRITICAL（大小寫皆可，啟動腳本會轉小寫）
# 同時被 app/core/config.py 的 Settings.LOG_LEVEL 與 scripts/start.sh 的 uvicorn 讀取
LOG_LEVEL=INFO


# -----------------------------------------------------------------------------
# Supabase PostgreSQL 資料庫
# -----------------------------------------------------------------------------
# 方案 A（推薦，Railway / Supabase 插件自動注入即走這條）：
#   顯式設 DATABASE_URL；config.py 的 ASYNC_DATABASE_URL 會自動補上 +asyncpg 驅動，
#   Alembic 用的同步版本也會自動去掉驅動後綴，不需另外設。
# Gotcha：常駐的 Railway 容器務必走 Supabase session-mode pooler（port 5432），
#   不要用 transaction-mode（port 6543）。6543 的 PgBouncer 會讓 asyncpg 的 JSONB
#   codec 型別 introspection 之 prepared statement 跨 backend 失效，造成特定端點 500
#   （錯誤訊息：`prepared statement "__asyncpg_stmt_*__" does not exist`）。
#   session-mode 每個 client 連線對應專屬 backend，prepared statement 才會持久。
#   config.py 的 _is_supabase 偵測是從 ASYNC_DATABASE_URL 解析 host（而非看 DB_HOST，
#   因為以完整 DATABASE_URL 注入時 DB_HOST 仍是預設 localhost，否則 mitigation 會全失效）。
#   正式環境 host 範例：aws-1-ap-southeast-1.pooler.supabase.com（session pooler 用戶名為 postgres.[YOUR-PROJECT-REF]）
DATABASE_URL=postgresql+asyncpg://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres
# 方案 B（本機 / docker-compose 開發）：不設 DATABASE_URL，改用下列元件組合：
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=gu_voice
# DB_USER=gu_app
# DB_PASSWORD=your-db-password
# 連線池設定
# 注意：Supabase session pooler 連線數有限，正式環境請把連線池調小（5 / 5）。
#   若改走直連 Postgres 或本機開發，可放大為 20 / 10。
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5

# Supabase 專案設定（用於 Supabase Client SDK，如 Storage、Realtime 等）
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key


# -----------------------------------------------------------------------------
# Redis 快取
# -----------------------------------------------------------------------------
# 方案 A（Railway Redis / Upstash 插件注入即用）：顯式設 REDIS_URL
REDIS_URL=redis://default:your-password@your-redis-host:6379
# 方案 B（本機開發）：不設 REDIS_URL，用以下元件：
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
# Redis 鍵值前綴（避免多環境衝突）
REDIS_KEY_PREFIX=gu_prod:
# P3 #29：cache / celery broker / celery result 各走獨立 DB index，
# 防止 FLUSHDB on cache 把 Celery 佇列一起清掉
REDIS_DB_CACHE=0
REDIS_DB_CELERY_BROKER=1
REDIS_DB_CELERY_RESULT=2


# -----------------------------------------------------------------------------
# JWT 認證設定
# -----------------------------------------------------------------------------
JWT_ALGORITHM=RS256
# RS256 金鑰：config.py 會自動判別——
#   值包含 "BEGIN" → 當 PEM 內容（Railway 常這樣貼，\n 字面會自動還原成真換行）
#   否則當檔案路徑 → 從該路徑讀取 PEM
#   都沒設 → fallback 到 JWT_PRIVATE_KEY_PATH / JWT_PUBLIC_KEY_PATH（預設 keys/*.pem）
# 產生方式：openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_CONTENT\n-----END PUBLIC KEY-----
# 本機開發替代：直接指向檔案路徑
# JWT_PRIVATE_KEY_PATH=keys/private.pem
# JWT_PUBLIC_KEY_PATH=keys/public.pem
# Access Token 有效期（分鐘）
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Refresh Token 有效期（天）
REFRESH_TOKEN_EXPIRE_DAYS=7


# -----------------------------------------------------------------------------
# OpenAI API 設定
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key
# 各功能使用的模型（2026-04-15 production 對齊）
# Conversation + Supervisor: gpt-5.4-mini(reasoning 模型家族,2026-03 發佈,
#   400K context,knowledge cutoff 2025-08-31)
# SOAP: gpt-4o(報告產生對語氣要求較低,gpt-4o 成本合理)
# Red flag: gpt-4o-mini(速度優先)
OPENAI_MODEL_CONVERSATION=gpt-5.4-mini
OPENAI_MODEL_SUPERVISOR=gpt-5.4-mini
OPENAI_MODEL_SOAP=gpt-4o
OPENAI_MODEL_RED_FLAG=gpt-4o-mini
# 模型參數
OPENAI_TEMPERATURE_CONVERSATION=0.7
OPENAI_TEMPERATURE_SOAP=0.3
OPENAI_TEMPERATURE_RED_FLAG=0.2
OPENAI_MAX_TOKENS_CONVERSATION=2048
OPENAI_MAX_TOKENS_SOAP=4096
OPENAI_MAX_TOKENS_RED_FLAG=1024
# reasoning_effort 控制（gpt-5.4 系列等 reasoning 模型支援）:
#   none                        → 不送 reasoning_effort,改送 temperature
#                                 (走傳統 chat 路徑,gpt-4o / gpt-4.1 也走這條)
#   low / medium / high / xhigh → 啟用 chain-of-thought;API 會拒絕 temperature,
#                                 程式端會自動不送 temperature
# Conversation=none 保留語音問診的口吻親和 + 低延遲
# Supervisor=medium 背景督導啟用 CoT 拿到更精準的 next_focus
OPENAI_REASONING_EFFORT_CONVERSATION=none
OPENAI_REASONING_EFFORT_SUPERVISOR=medium
# 請求逾時（秒）
OPENAI_REQUEST_TIMEOUT=60
# 每分鐘最大請求數（速率限制）
OPENAI_RATE_LIMIT_RPM=60


# -----------------------------------------------------------------------------
# Google Cloud 語音服務
# -----------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
# 在 Railway 上無法掛載檔案，請將 Service Account JSON 以 base64 編碼後貼入
# 產生方式：base64 -i service-account.json | tr -d '\n'
GOOGLE_APPLICATION_CREDENTIALS_JSON=base64-encoded-service-account-json

# 語音轉文字（STT）設定
STT_LANGUAGE_CODE=zh-TW
STT_SAMPLE_RATE_HERTZ=16000
STT_ENCODING=WEBM_OPUS
# 啟用自動標點符號
STT_ENABLE_AUTOMATIC_PUNCTUATION=true
# 啟用口語化字詞處理
STT_ENABLE_SPOKEN_PUNCTUATION=false
# 醫學專業術語 boost（提高辨識準確度）
STT_MEDICAL_BOOST=20

# 文字轉語音（TTS）設定
TTS_LANGUAGE_CODE=zh-TW
TTS_VOICE_NAME=zh-TW-Standard-A
TTS_SPEAKING_RATE=1.0
TTS_PITCH=0.0
TTS_AUDIO_ENCODING=MP3


# -----------------------------------------------------------------------------
# Sentry 錯誤追蹤
# -----------------------------------------------------------------------------
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_PROFILES_SAMPLE_RATE=0.1
# 環境標籤（對應 APP_ENV）
SENTRY_ENVIRONMENT=production


# -----------------------------------------------------------------------------
# Firebase Cloud Messaging（推播通知）
# -----------------------------------------------------------------------------
# 與 Google Cloud 類似，以 base64 編碼的 Firebase Service Account JSON
FCM_CREDENTIALS_JSON=base64-encoded-fcm-service-account-json


# -----------------------------------------------------------------------------
# Celery 非同步任務佇列
# -----------------------------------------------------------------------------
# 使用 Redis 作為 Broker（與快取共用 Redis 或獨立 Redis）
CELERY_BROKER_URL=redis://default:your-password@your-redis-host:6379/1
CELERY_RESULT_BACKEND=redis://default:your-password@your-redis-host:6379/2
# Worker 並行數
CELERY_WORKER_CONCURRENCY=4
# 任務預設逾時（秒）
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600


# -----------------------------------------------------------------------------
# WebSocket 設定
# -----------------------------------------------------------------------------
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=100
WS_MESSAGE_MAX_SIZE=1048576


# -----------------------------------------------------------------------------
# Email（P3 #31 forgot_password）
# -----------------------------------------------------------------------------
# 前端 reset-password 頁面 base URL；email 會拼成
# `{FRONTEND_BASE_URL}/reset-password?token=...`
FRONTEND_BASE_URL=https://your-frontend-domain.com
# 寄信 transport 優先順序：SENDGRID_API_KEY > SMTP_HOST > 皆無 → log-only（dev）
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=no-reply@gu-voice.local
SMTP_USE_TLS=true


# -----------------------------------------------------------------------------
# 其他設定
# -----------------------------------------------------------------------------
# PDF 報告暫存目錄
PDF_TEMP_DIR=/tmp/pdf_reports
# 檔案上傳大小限制（bytes）
MAX_UPLOAD_SIZE=10485760
