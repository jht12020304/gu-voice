# =============================================================================
# 泌尿科 AI 語音問診助手 — 環境變數範本
# 複製此檔案為 .env 並填入實際值
# 注意：請勿將 .env 提交至版本控制
# =============================================================================


# -----------------------------------------------------------------------------
# 應用程式基本設定
# -----------------------------------------------------------------------------
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=your-super-secret-key-at-least-32-characters-long
# 允許的前端來源（CORS），多個用逗號分隔
CORS_ORIGINS=https://your-frontend-domain.com,https://your-admin-domain.com
# 日誌等級：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO


# -----------------------------------------------------------------------------
# Supabase PostgreSQL 資料庫
# -----------------------------------------------------------------------------
# Railway 上可透過 Supabase 插件自動注入，或手動填入
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
# 連線池設定
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# Supabase 專案設定（用於 Supabase Client SDK，如 Storage、Realtime 等）
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key


# -----------------------------------------------------------------------------
# Redis 快取
# -----------------------------------------------------------------------------
# Railway Redis 插件會自動注入此變數，或使用 Upstash Redis
REDIS_URL=redis://default:your-password@your-redis-host:6379
# Redis 鍵值前綴（避免多環境衝突）
REDIS_KEY_PREFIX=gu_prod:


# -----------------------------------------------------------------------------
# JWT 認證設定
# -----------------------------------------------------------------------------
JWT_ALGORITHM=RS256
# 注意：在 Railway 上請將金鑰內容直接貼入環境變數（非檔案路徑）
# 產生方式：openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# 將 private.pem 內容貼入 JWT_PRIVATE_KEY，public.pem 內容貼入 JWT_PUBLIC_KEY
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_CONTENT\n-----END PUBLIC KEY-----
# Access Token 有效期（分鐘）
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
# Refresh Token 有效期（天）
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7


# -----------------------------------------------------------------------------
# OpenAI API 設定
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key
# 各功能使用的模型
OPENAI_MODEL_CONVERSATION=gpt-4o
OPENAI_MODEL_SOAP=gpt-4o
OPENAI_MODEL_RED_FLAG=gpt-4o-mini
# 模型參數
OPENAI_TEMPERATURE_CONVERSATION=0.7
OPENAI_TEMPERATURE_SOAP=0.3
OPENAI_TEMPERATURE_RED_FLAG=0.2
OPENAI_MAX_TOKENS_CONVERSATION=2048
OPENAI_MAX_TOKENS_SOAP=4096
OPENAI_MAX_TOKENS_RED_FLAG=1024
# 請求逾時（秒）
OPENAI_REQUEST_TIMEOUT=60
# 每分鐘最大請求數（速率限制）
OPENAI_RATE_LIMIT_RPM=60


# -----------------------------------------------------------------------------
# Google Cloud 語音服務
# -----------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
# 在 Railway 上無法掛載檔案，請將 Service Account JSON 以 base64 編碼後貼入
# 產生方式：base64 -i service-account.json | tr -d '\n'
GOOGLE_APPLICATION_CREDENTIALS_JSON=base64-encoded-service-account-json

# 語音轉文字（STT）設定
STT_LANGUAGE_CODE=zh-TW
STT_SAMPLE_RATE_HERTZ=16000
STT_ENCODING=WEBM_OPUS
# 啟用自動標點符號
STT_ENABLE_AUTOMATIC_PUNCTUATION=true
# 啟用口語化字詞處理
STT_ENABLE_SPOKEN_PUNCTUATION=false
# 醫學專業術語 boost（提高辨識準確度）
STT_MEDICAL_BOOST=20

# 文字轉語音（TTS）設定
TTS_LANGUAGE_CODE=zh-TW
TTS_VOICE_NAME=zh-TW-Standard-A
TTS_SPEAKING_RATE=1.0
TTS_PITCH=0.0
TTS_AUDIO_ENCODING=MP3


# -----------------------------------------------------------------------------
# Sentry 錯誤追蹤
# -----------------------------------------------------------------------------
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_PROFILES_SAMPLE_RATE=0.1
# 環境標籤（對應 APP_ENV）
SENTRY_ENVIRONMENT=production


# -----------------------------------------------------------------------------
# Firebase Cloud Messaging（推播通知）
# -----------------------------------------------------------------------------
# 與 Google Cloud 類似，以 base64 編碼的 Firebase Service Account JSON
FCM_CREDENTIALS_JSON=base64-encoded-fcm-service-account-json


# -----------------------------------------------------------------------------
# Celery 非同步任務佇列
# -----------------------------------------------------------------------------
# 使用 Redis 作為 Broker（與快取共用 Redis 或獨立 Redis）
CELERY_BROKER_URL=redis://default:your-password@your-redis-host:6379/1
CELERY_RESULT_BACKEND=redis://default:your-password@your-redis-host:6379/2
# Worker 並行數
CELERY_WORKER_CONCURRENCY=4
# 任務預設逾時（秒）
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600


# -----------------------------------------------------------------------------
# WebSocket 設定
# -----------------------------------------------------------------------------
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=100
WS_MESSAGE_MAX_SIZE=1048576


# -----------------------------------------------------------------------------
# 其他設定
# -----------------------------------------------------------------------------
# PDF 報告暫存目錄
PDF_TEMP_DIR=/tmp/pdf_reports
# 檔案上傳大小限制（bytes）
MAX_UPLOAD_SIZE=10485760
