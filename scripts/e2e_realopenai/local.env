# =============================================================================
# E2E 本機環境覆寫（疊在 backend/.env 之上；export 後再起 uvicorn / alembic）
# 用法： set -a; source local.env; set +a
# - DATABASE_URL 顯式 URL 走 config.py 優先分支（sync/async 都會轉換 driver）
# - DB_HOST=localhost 讓 alembic env.py 的 Supabase SSL 判斷不觸發
# - REDIS_KEY_PREFIX 必須是 gu:（conversation_handler 讀 supervisor_guidance
#   時 hardcode "gu:session:{id}:supervisor_guidance"，supervisor 寫入用
#   settings.REDIS_KEY_PREFIX——prefix 不是 gu: 整條 guidance 迴路會斷）
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:55432/gu_voice
DB_HOST=localhost
DB_PORT=55432
DB_NAME=gu_voice
DB_USER=postgres
DB_PASSWORD=postgres
REDIS_URL=redis://localhost:56379/0
REDIS_KEY_PREFIX=gu:
APP_ENV=development
LOG_LEVEL=INFO
