# ============================================================
# 泌尿科 AI 語音問診助手 - 前端環境變數
# ============================================================
# 複製此檔案為 .env.local 並填入實際值
# cp .env.example .env.local
# ============================================================

# --- 應用程式環境 ---
# 可選值: development | staging | production
VITE_APP_ENV=development

# --- 後端 API (Railway) ---
# Railway 部署的後端 API 基礎網址
# 注意：生產環境（Vercel）的 VITE_API_BASE_URL / VITE_WS_BASE_URL 由 Vercel dashboard
# 的環境變數設定，會「覆寫」repo 內的 .env.production；本檔僅供本地 .env.local 參考。
# 生產後端參考：https://gu-voice-app-production.up.railway.app
VITE_API_BASE_URL=https://your-app.railway.app/api/v1

# Railway 部署的 WebSocket 基礎網址（需含 /api/v1 前綴，與後端 ws router 掛載路徑一致）
VITE_WS_BASE_URL=wss://your-app.railway.app/api/v1/ws

# --- Supabase 認證 ---
# Supabase 專案網址
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase 匿名公鑰（前端安全使用）
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- 監控與錯誤追蹤 ---
# Sentry DSN（錯誤追蹤，生產環境建議啟用）
VITE_SENTRY_DSN=

# --- 開發用選項 ---
# 啟用 Mock API（本地開發時使用，設為 true 啟用）
VITE_ENABLE_MOCK=false
